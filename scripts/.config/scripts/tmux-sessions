#!/usr/bin/env bash

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
preview_script="$script_dir/tmux-sessions-preview"

# Load configuration
# Priority: 1. Environment variable, 2. Defaults
if [[ -n "$TMUX_SESSION_DIRS" ]]; then
    # Use environment variable (colon-separated paths)
    IFS=':' read -ra search_dirs <<< "$TMUX_SESSION_DIRS"
else
    # Use defaults based on OS
    if [ "$(uname)" = "Darwin" ]; then
        search_dirs=("$HOME/.config" "$HOME/projects")
    elif [ "$(uname)" = "Linux" ]; then
        search_dirs=("$HOME/.config" "$HOME/work" "$HOME/private" "$HOME/projects")
    fi
fi

# Function to annotate directories with session status
annotate_with_sessions() {
    while IFS= read -r dir; do
        session_name=$(basename "$dir" | tr '. ' '_' | tr -cd '[:alnum:]_-')
        if tmux has-session -t "$session_name" 2>/dev/null; then
            echo "$dir [●]"
        else
            echo "$dir"
        fi
    done
}

if [[ $# -eq 1 ]]; then
    session=$1
else
    # Build find command with all search directories
    find_args=()
    for dir in "${search_dirs[@]}"; do
        # Expand tilde and check if directory exists
        expanded_dir="${dir/#\~/$HOME}"
        if [[ -d "$expanded_dir" ]]; then
            find_args+=("$expanded_dir")
        fi
    done

    if [[ ${#find_args[@]} -eq 0 ]]; then
        echo "Error: No valid search directories found" >&2
        exit 1
    fi

    session=$(find "${find_args[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | \
        annotate_with_sessions | \
        fzf --layout=reverse --border --preview "$preview_script {}" --preview-window=right:50%:wrap --header='Select a project directory (● = active session)')
fi

if [[ -z "$session" ]]; then
    exit 0
fi

# Strip the session indicator if present
session=${session% \[●\]}

session_name=$(basename "$session" | tr '. ' '_' | tr -cd '[:alnum:]_-')
tmux_running=$(tmux list-sessions 2>/dev/null)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$session_name" -c "$session"
    exit 0
fi

if ! tmux has-session -t "$session_name" 2>/dev/null; then
    tmux new-session -s "$session_name" -c "$session" -d
fi

if [[ -z $TMUX ]] && [[ $tmux_running ]]; then
    tmux attach-session -t "$session_name"
else
    tmux switch-client -t "$session_name"
fi
