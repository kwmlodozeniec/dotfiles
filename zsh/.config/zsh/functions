#!/usr/bin/env zsh

function make-env() {
    local VENV_NAME="${1:-.venv}"
    local PYTHON_VER="${2:-3.12}"
    uv venv --python $PYTHON_VER $VENV_NAME
    source $VENV_NAME/bin/activate
}

function activate-env() {
    local VENV_NAME=${1:-.venv}
    source $VENV_NAME/bin/activate
}

function git-short-log() {
    local NUMBER=${1:-10}
    git --no-pager log --pretty=oneline --abbrev-commit -n $NUMBER
}

function git-rebase() {
    local NUMBER="${1:-10}"
    git rebase --interactive HEAD~$NUMBER
}

function git-push-force() {
    git push --force
}

function git-fetch-prune() {
    git fetch --prune --all --tags
}

function git-branch-list() {
    git --no-pager branch --all --list
}

function git-branch-delete() {
    git branch --delete --force $1
}

function git-branch-switch() {clear

    git switch $1
}

function load-env() {
    local ENV_FILE="${1:-.env}"
    export $(grep -v '^#' $ENV_FILE | xargs)
}

function unload-env() {
    local ENV_FILE="${1:-.env}"
    unset $(grep -v '^#' $ENV_FILE | sed -E 's/(.*)=.*/\1/' | xargs)
}

cleanup-gone-branches() {
  local delete=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --delete|-d)
        delete=1
        shift
        ;;
      -h|--help)
        cat <<'EOF'
Usage: cleanup-gone-branches [--delete|-d]

List local branches whose upstream is gone.
EOF
        return 0
        ;;
      *)
        echo "Unknown argument: $1" >&2
        return 1
        ;;
    esac
  done

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Not inside a git repository." >&2
    return 1
  fi

  git fetch --prune

  local current_branch
  current_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null)"

  local -a branches
  local branch tracking

  while IFS=$'\t' read -r branch tracking; do
    [[ -z "$branch" ]] && continue
    [[ -n "$current_branch" && "$branch" == "$current_branch" ]] && continue
    [[ "$tracking" == *"[gone]"* ]] && branches+=("$branch")
  done < <(
    git for-each-ref \
      --format=$'%(refname:short)\t%(upstream:track)' \
      refs/heads
  )

  if [[ ${#branches[@]} -eq 0 ]]; then
    echo "No branches with gone upstreams."
    return 0
  fi

  echo "Branches with gone upstreams:"
  printf '  %s\n' "${branches[@]}"

  if [[ $delete -eq 0 ]]; then
    echo
    echo "Dry run. Re-run with --delete to remove them."
    return 0
  fi

  echo
  printf 'Delete these branches? [y/N] '
  read -r answer

  case "$answer" in
    y|Y|yes|YES)
      local failed=0
      for branch in "${branches[@]}"; do
        if git branch -d -- "$branch"; then
          echo "Deleted $branch"
        else
          echo "Failed to delete $branch" >&2
          failed=1
        fi
      done
      return $failed
      ;;
    *)
      echo "Aborted."
      return 0
      ;;
  esac
}

alias cgb="cleanup-gone-branches"

function auto-venv() {
    # Deactivate venv if we have left project directory
    if [[ -n "$VIRTUAL_ENV" && "$PWD" != *"${VIRTUAL_ENV:h}"* ]]; then
        deactivate
        return
    fi

    # Already in a venv for current project so do nothing
    if [[ -n "$VIRTUAL_ENV" ]]; then
        return
    fi

    local dir="$PWD"
    local venv_names=(".venv" "venv")

    while [[ "$dir" != "/" ]]; do
        for name in "${venv_names[@]}"; do
            local activate_path="$dir/$name/bin/activate"
            if [[ -f "$activate_path" ]]; then
                source "$activate_path"
                return
            fi
        done
        dir="${dir:h}"
    done
}

# Run command on directory change
autoload -Uz add-zsh-hook
add-zsh-hook chpwd auto-venv

# Open buffer line in editor
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^x^e' edit-command-line

# Enable zmv
autoload -Uz zmv
